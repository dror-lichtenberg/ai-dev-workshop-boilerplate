{
  "name": "AI Dev Workshop Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-vscode.live-server",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "editor.formatOnSave": true,
        "editor.rulers": [88],
        "files.autoSave": "onFocusChange",
        "github.copilot.advanced": {
          "length": 500,
          "listCount": 10,
          "temperature": 0.1
        }
      }
    }
  },
  "postCreateCommand": "cd starter && pip install -r requirements.txt && cd .. && git config --global user.name 'Workshop Student' && git config --global user.email 'student@workshop.local' && echo '✅ Environment ready! You can start the exercises now.'",
  "remoteUser": "vscode",
  "forwardPorts": [8000, 5000]
}
